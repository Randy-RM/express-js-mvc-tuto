model User {
  id               String    @id @default(uuid())
  username         String
  email            String    @unique
  password         String
  isUserActive     Boolean   @default(false)
  uniqueString     String?
  resetToken       String?
  resetTokenExpiry DateTime?
  role             Role      @default(user)
  articles         Article[]
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
}
